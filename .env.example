# =============================================================================
# Ambiente LOCAL (padrão) — Docker Compose, sem nuvem obrigatória
# =============================================================================
DEPLOY_TARGET=local
NODE_ENV=development

# TypeORM: dev usa synchronize; prod usa migrations (ver infra/migrations/README.md)
# TYPEORM_SYNC=false
# TYPEORM_RUN_MIGRATIONS=true

# Capacidades (drivers) — ver docs/env-contract.md
AUTH_PROVIDER=local-jwt
STORAGE_BACKEND=local
LLM_PROVIDER=mock

# Infraestrutura local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379

# URLs internas (Docker)
AUTH_SERVICE_URL=http://auth-service:3001
CATALOG_SERVICE_URL=http://catalog-service:3002
TABLES_SERVICE_URL=http://tables-service:3003
ORDERS_SERVICE_URL=http://orders-service:3004
AI_SERVICE_URL=http://ai-service:3005
REALTIME_SERVICE_URL=http://realtime-service:3006
ADMIN_SERVICE_URL=http://admin-service:3007

# App (host)
APP_URL=http://localhost:4201
API_URL=http://localhost:3008
JWT_SECRET=dev-jwt-secret-change-in-production

# Mídia local (catalog-service)
UPLOAD_DIR=/app/uploads/produtos
MEDIA_PUBLIC_PATH=/api/media/produtos

# =============================================================================
# IA — mock local (padrão). Nuvem futura: aws-bedrock | gcp-vertex | azure-openai
# Templates: env/cloud/aws.env.example | gcp.env.example | azure.env.example
# =============================================================================
BEDROCK_MOCK=true

# AWS Bedrock (só quando LLM_PROVIDER=aws-bedrock e BEDROCK_MOCK=false)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=1

# GCP (futuro) — Vertex AI
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# VERTEX_MODEL_ID=

# Azure (futuro) — OpenAI + AI Search
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
