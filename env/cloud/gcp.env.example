# Template Google Cloud — copiar valores para .env no deploy (não commitar secrets)
DEPLOY_TARGET=gcp
NODE_ENV=production

APP_URL=https://app.seudominio.com
API_URL=https://api.seudominio.com

AUTH_PROVIDER=gcp-identity
STORAGE_BACKEND=gcs
LLM_PROVIDER=gcp-vertex

# Cloud SQL / Memorystore
DATABASE_URL=postgresql://user:pass@/restaurante_auth?host=/cloudsql/PROJECT:REGION:INSTANCE
REDIS_URL=redis://10.0.0.5:6379

GCP_PROJECT_ID=
GCP_REGION=us-central1

STORAGE_BUCKET=restaurante-media-prod
STORAGE_REGION=us-central1
MEDIA_PUBLIC_PATH=/api/media/produtos

VERTEX_MODEL_ID=gemini-2.0-flash
VERTEX_KB_RESOURCE=

# Cloud Run — URLs internas ou service mesh
AUTH_SERVICE_URL=https://auth-service-xxx.run.app
CATALOG_SERVICE_URL=https://catalog-service-xxx.run.app
TABLES_SERVICE_URL=https://tables-service-xxx.run.app
ORDERS_SERVICE_URL=https://orders-service-xxx.run.app
AI_SERVICE_URL=https://ai-service-xxx.run.app
REALTIME_SERVICE_URL=https://realtime-service-xxx.run.app
ADMIN_SERVICE_URL=https://admin-service-xxx.run.app
