# Template AWS — copiar valores para .env no ambiente de deploy (não commitar secrets)
DEPLOY_TARGET=aws
NODE_ENV=production

APP_URL=https://app.seudominio.com
API_URL=https://api.seudominio.com

AUTH_PROVIDER=aws-cognito
STORAGE_BACKEND=s3
LLM_PROVIDER=aws-bedrock

# RDS / ElastiCache (exemplo — usar Secrets Manager na prática)
DATABASE_URL=postgresql://user:pass@rds-host:5432/restaurante_auth
REDIS_URL=rediss://elasticache-host:6379

JWT_SECRET=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

STORAGE_BUCKET=restaurante-media-prod
STORAGE_REGION=us-east-1
MEDIA_PUBLIC_PATH=/api/media/produtos

AWS_REGION=us-east-1
BEDROCK_MOCK=false
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=1

# URLs internas ECS (service discovery ou Cloud Map)
AUTH_SERVICE_URL=http://auth-service:3001
CATALOG_SERVICE_URL=http://catalog-service:3002
TABLES_SERVICE_URL=http://tables-service:3003
ORDERS_SERVICE_URL=http://orders-service:3004
AI_SERVICE_URL=http://ai-service:3005
REALTIME_SERVICE_URL=http://realtime-service:3006
ADMIN_SERVICE_URL=http://admin-service:3007
