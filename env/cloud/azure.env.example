# Template Microsoft Azure — copiar valores para .env no deploy (não commitar secrets)
DEPLOY_TARGET=azure
NODE_ENV=production

APP_URL=https://app.seudominio.com
API_URL=https://api.seudominio.com

AUTH_PROVIDER=azure-entra
STORAGE_BACKEND=azure-blob
LLM_PROVIDER=azure-openai

# Azure Database for PostgreSQL / Azure Cache for Redis
DATABASE_URL=postgresql://user:pass@server.postgres.database.azure.com:5432/restaurante_auth?sslmode=require
REDIS_URL=rediss://cache.redis.cache.windows.net:6380

AZURE_TENANT_ID=
AZURE_CLIENT_ID=

STORAGE_BUCKET=restaurante-media
STORAGE_REGION=brazilsouth
MEDIA_PUBLIC_PATH=/api/media/produtos

AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_AI_SEARCH_ENDPOINT=

# Container Apps — URLs internas
AUTH_SERVICE_URL=https://auth-service.internal
CATALOG_SERVICE_URL=https://catalog-service.internal
TABLES_SERVICE_URL=https://tables-service.internal
ORDERS_SERVICE_URL=https://orders-service.internal
AI_SERVICE_URL=https://ai-service.internal
REALTIME_SERVICE_URL=https://realtime-service.internal
ADMIN_SERVICE_URL=https://admin-service.internal
